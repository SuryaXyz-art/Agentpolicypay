{
    "compilerOptions":  {
                            "target":  "ES2017",
                            "lib":  [
                                        "dom",
                                        "dom.iterable",
                                        "esnext"
                                    ],
                            "allowJs":  false,
                            "skipLibCheck":  true,
                            "strict":  true,
                            "noEmit":  true,
                            "esModuleInterop":  true,
                            "module":  "esnext",
                            "moduleResolution":  "bundler",
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "jsx":  "preserve",
                            "incremental":  true,
                            "plugins":  [
                                            {
                                                "name":  "next"
                                            }
                                        ],
                            "paths":  {
                                          "@/*":  [
                                                      "./frontend/*"
                                                  ]
                                      },
                            "baseUrl":  "."
                        },
    "include":  [
                    "hardhat.config.ts",
                    "scripts/**/*.ts",
                    "frontend/**/*.ts",
                    "frontend/**/*.tsx"
                ],
    "exclude":  [
                    "node_modules"
                ]
}
